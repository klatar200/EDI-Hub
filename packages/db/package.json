{
  "name": "@edi/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test": "tsc --build && node --test --import tsx test/*.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:generate:sqlite": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "db:migrate:sqlite": "prisma db push --schema=prisma/schema.sqlite.prisma --accept-data-loss --skip-generate"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2"
  }
}
