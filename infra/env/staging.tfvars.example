# Copy to env/staging.tfvars and fill in real IDs.
# Never commit staging.tfvars — it may contain environment-specific identifiers.
# Secrets (db password, Clerk keys) go in Secrets Manager or TF_VAR_*, not here.

environment = "staging"

# S3 raw-file bucket — must be globally unique
bucket_name        = "edi-raw-files-staging-YOUR_ACCOUNT_ID"
environment_prefix = "edi/staging"

# RDS
db_name                  = "edi_hub"
db_master_username       = "edi_admin"
# db_master_password     → export TF_VAR_db_master_password='...' before apply

# Networking — use a VPC with private subnets for RDS and public subnets for ALB
vpc_id                   = "vpc-xxxxxxxx"
public_subnet_ids        = ["subnet-public-a", "subnet-public-b"]
db_subnet_ids            = ["subnet-private-a", "subnet-private-b"]
db_allowed_security_group_ids = ["sg-api-task-staging"]

# DNS + TLS (ACM cert validated via Route 53)
public_domain   = "api.staging.edihub.example.com"
route53_zone_id = "Z123EXAMPLE"

# Phase 10 backups (fill after ECR image exists — see infra/backup-container/)
# backup_bucket_name         = "edi-hub-backups-staging-YOUR_ACCOUNT_ID"
# backup_replica_bucket_name = "edi-hub-backups-staging-replica-YOUR_ACCOUNT_ID"
# backup_image               = "123456789012.dkr.ecr.us-east-1.amazonaws.com/edi-hub-backup:latest"
# backup_subnet_ids          = ["subnet-private-a", "subnet-private-b"]
# backup_cluster_arn         = "arn:aws:ecs:us-east-1:123456789012:cluster/edi-hub-staging"
