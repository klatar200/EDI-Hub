# Desktop installer environment template (D2 Sprint 2).
#
# The desktop installer launches the API with these env vars set by the
# Electron main process (D4). This file documents the contract so manual
# `npm run dev` invocations on a developer machine can mirror the same shape
# without having to dig through the Electron source.
#
# Copy to `.env.desktop` (gitignored) and tweak per machine.

# Use the in-process Postgres-backed job queue (no Redis required).
# Allowed: 'db' (only supported value in D2 Sprint 1).
JOB_BACKEND=db

# Use the local-filesystem raw-file adapter (no S3 required).
# Allowed: 'local' | 's3'. Default is 's3'; the installer flips it.
# (Adapter implementation lands in D3.)
STORAGE_BACKEND=local

# Connect to the installer's embedded Postgres on the canonical local port.
# D4 Sprint 1 starts `postgres` here from `<userData>/postgres/bin/`.
DATABASE_URL=postgresql://localhost:5433/edihub

# Use the Postgres-typed Prisma client (the installer always uses Postgres;
# SQLite is dev-only). Explicit for clarity.
DATABASE_PROVIDER=postgresql

# Local dev folder for raw files. The installer overrides this with
# `<userData>/raw/`; the example points at a sibling folder so manual runs
# don't write into your home directory.
LOCAL_DATA_DIR=./.desktop-data/raw

# D4 Sprint 2 — the API process serves the React build at / from the
# same port (3000) it serves /api/* on. The installer sets WEB_STATIC_DIR
# to the bundled apps/web/dist path; manual runs point it at your built
# tree. Empty disables static serving entirely (SaaS / pure-web-dev mode).
WEB_STATIC_DIR=./apps/web/dist

# Bind the API on 0.0.0.0 (already the default) and use port 3000 so
# LAN clients can reach the hub at http://<server-ip>:3000.
PORT=3000

# Clerk - the desktop installer shares one Clerk app with the SaaS build.
# Copy the same keys you use in your root `.env`; the installer ships
# them unmodified. Both keys are required in production; if either is
# blank the API falls back to "pilot tenant" mode (every request is
# pinned to the seed tenant — fine for local poking, never for a real
# install).
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# D4 Sprint 2 — Clerk verifies the JWT's `azp` (authorized party) claim
# against this allowlist. Localhost is fine for testing on the install
# machine; LAN clients hitting http://<server-ip>:3000 need <server-ip>
# in the list too. The installer-side first-run wizard (D8 Sprint 2)
# will populate this automatically; for manual installs:
#   CLERK_AUTHORIZED_PARTIES=http://localhost:3000,http://10.0.0.57:3000
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
