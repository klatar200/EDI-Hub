# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Prisma generated client
packages/db/generated/

# Environment / secrets — never commit
.env
.env.*
!.env.example

# Logs
*.log
logs/

# OS / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Local data volumes
.data/
tmp/



# SFTP drop folders (local dev)
.sftp/

# AS2 drop folders (local dev)
.as2/

# Desktop installer build output
apps/desktop/dist-installer/

# Playwright test artifacts
test-results/
playwright-report/

# Vite dev-mode timestamp artifacts (Vite writes these on hot reload)
apps/web/vite.config.ts.timestamp-*.mjs

# .continue/ — IDE-side AI assistant cache
.continue/

