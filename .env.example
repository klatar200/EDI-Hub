# ─────────────────────────────────────────────────────────────
# EDI Data Hub — environment variables
# Copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- API ---
# Port the Fastify API listens on
PORT=3000
# Node environment: development | test | production
NODE_ENV=development
# Max accepted upload size in bytes (default 25 MB)
MAX_FILE_SIZE_BYTES=26214400

# --- Database (PostgreSQL) ---
# Local dev points at the docker-compose Postgres service.
DATABASE_URL=postgresql://edi:edi@localhost:5432/edi_hub?schema=public

# --- Object storage (S3 / MinIO) ---
# For local dev these point at the docker-compose MinIO service.
# For real AWS, set S3_ENDPOINT empty (SDK uses the regional endpoint),
# set the region, and supply real IAM credentials.
S3_BUCKET=edi-raw-files
S3_REGION=us-east-1
# Leave S3_ENDPOINT set for MinIO; clear it (or remove) for real AWS S3.
S3_ENDPOINT=http://localhost:9000
# Required true for MinIO (path-style URLs); false for real AWS S3.
S3_FORCE_PATH_STYLE=true
# Credentials — MinIO defaults below; replace with IAM keys for AWS.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# --- Ingestion: retry (S3 transient failures) ---
S3_MAX_RETRIES=3
S3_RETRY_BASE_DELAY_MS=200

# --- Ingestion: SFTP folder-watch (Sprint 2) ---
# Set true to watch a drop folder fed by the docker-compose SFTP service.
SFTP_WATCH_ENABLED=false
SFTP_WATCH_DIR=./.sftp/incoming
SFTP_PROCESSED_DIR=./.sftp/processed
SFTP_FAILED_DIR=./.sftp/failed
SFTP_STABILITY_MS=500

# --- Ingestion: AS2 receive (Phase 8 Sprint 2) ---
# AS2 receive is a thin watcher on the OpenAS2 daemon's plaintext inbox. The
# daemon handles the AS2 handshake (signature, encryption, MDN); we ingest only
# the decrypted EDI bytes it drops on disk. Stand the daemon up via
# `docker compose --profile as2 up` (see docker-compose.yml).
AS2_ENABLED=false
AS2_INBOX_DIR=./.as2/inbox
AS2_PROCESSED_DIR=./.as2/processed
AS2_FAILED_DIR=./.as2/failed
AS2_STABILITY_MS=500

# --- Lifecycle direction (Phase 4) ---
# Comma-separated list of ISA sender/receiver IDs that represent "us" (the hub
# operator). Compared (case-sensitive, trimmed) against the interchange ISA06
# (sender) and ISA08 (receiver) to tag each transaction inbound / outbound.
# Pre-Phase 9 this is a single list; Phase 9 makes it per-tenant.
OUR_ISA_IDS=

# --- Clerk auth (Phase 9 Sprint 2) ---
# Get these from the Clerk dashboard. See CLERK_SETUP.md for the full
# walkthrough. When CLERK_SECRET_KEY is blank, the API runs in dev-fallback
# mode: every request is pinned to the pilot tenant and the webhook endpoint
# is dormant. Production MUST set all three.
VITE_CLERK_PUBLISHABLE_KEY=REPLACE_ME_pk_test
CLERK_SECRET_KEY=REPLACE_ME_sk_test
CLERK_WEBHOOK_SECRET=REPLACE_ME_whsec

# --- Desktop LAN (SEC-C1) ---
# Optional bearer token for desktop hub production when Clerk is not configured.
# Min 32 characters. LAN clients send Authorization: Bearer <token>.
# EDI_HUB_LAN_API_TOKEN=
